<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>i.Translator - i.Logic Enterprise Solutions</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- React & ReactDOM -->
    <script src="https://unpkg.com/react@18/umd/react.production.min.js" crossorigin></script>
    <script src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js" crossorigin></script>
    <!-- Babel para JSX -->
    <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
    <!-- Phosphor Icons para iconos modernos -->
    <script src="https://unpkg.com/@phosphor-icons/web"></script>
    <!-- Tesseract.js para OCR local sin API Key -->
    <script src="https://cdn.jsdelivr.net/npm/tesseract.js@5/dist/tesseract.min.js"></script>
    
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: '#ffffff',
                        primaryHover: '#e5e7eb',
                        bgMain: '#000000',
                        bgSoft: '#0a0a0a',
                        borderSoft: '#262626',
                        textMain: '#ffffff',
                        textMuted: '#a3a3a3',
                    },
                    fontFamily: {
                        sans: ['Inter', 'ui-sans-serif', 'system-ui', '-apple-system', 'BlinkMacSystemFont', 'Segoe UI', 'Roboto', 'Helvetica Neue', 'Arial', 'sans-serif'],
                    }
                }
            }
        }
    </script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;900&display=swap');
        body {
            font-family: 'Inter', sans-serif;
            background-color: #000000;
            color: #ffffff;
        }
        
        /* Custom Scrollbar */
        textarea::-webkit-scrollbar { width: 8px; }
        textarea::-webkit-scrollbar-track { background: transparent; }
        textarea::-webkit-scrollbar-thumb { background-color: #333333; border-radius: 20px; }
        
        /* Animations */
        @keyframes pulse-subtle {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.6; }
        }
        .animate-pulse-subtle {
            animation: pulse-subtle 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
        }

        /* Mic pulse animation for dictation */
        @keyframes ping-slow {
            75%, 100% { transform: scale(1.5); opacity: 0; }
        }
        .animate-ping-slow {
            animation: ping-slow 2s cubic-bezier(0, 0, 0.2, 1) infinite;
        }

        /* Shimmer effect for i.Logic brand logo */
        @keyframes shimmer {
            100% { transform: translateX(100%); }
        }
    </style>
</head>
<body>
    <div id="root"></div>

    <script type="text/babel">
        const { useState, useEffect, useRef, useCallback } = React;

        // Lista de idiomas
        const LANGUAGES = [
            { code: 'auto', tess: 'eng+spa', name: 'Detectar idioma' },
            { code: 'es', tess: 'spa', name: 'Español' },
            { code: 'en', tess: 'eng', name: 'Inglés' },
            { code: 'fr', tess: 'fra', name: 'Francés' },
            { code: 'de', tess: 'deu', name: 'Alemán' },
            { code: 'it', tess: 'ita', name: 'Italiano' },
            { code: 'pt', tess: 'por', name: 'Portugués' },
            { code: 'ru', tess: 'rus', name: 'Ruso' },
            { code: 'zh', tess: 'chi_sim', name: 'Chino (Simp.)' },
            { code: 'ja', tess: 'jpn', name: 'Japonés' },
            { code: 'ko', tess: 'kor', name: 'Coreano' },
            { code: 'ar', tess: 'ara', name: 'Árabe' },
            { code: 'hi', tess: 'hin', name: 'Hindi' },
            { code: 'nl', tess: 'nld', name: 'Holandés' },
            { code: 'tr', tess: 'tur', name: 'Turco' },
            { code: 'pl', tess: 'pol', name: 'Polaco' },
            { code: 'sv', tess: 'swe', name: 'Sueco' },
            { code: 'vi', tess: 'vie', name: 'Vietnamita' }
        ];

        const Header = () => (
            <header className="bg-bgMain shadow-sm sticky top-0 z-10 border-b border-borderSoft">
                <div className="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
                    <div className="flex items-center gap-2 cursor-default group">
                        <div className="bg-gradient-to-br from-white to-gray-300 text-black p-1.5 rounded-lg shadow-sm transition-transform group-hover:scale-105">
                            <i className="ph ph-translate text-2xl"></i>
                        </div>
                        <h1 className="text-xl font-bold text-textMain tracking-tight">
                            i.<span className="font-black">Translator</span>
                        </h1>
                        <span className="ml-2 bg-[#1a1a1a] border border-borderSoft text-white text-[10px] font-bold px-2 py-0.5 rounded-full uppercase tracking-wider flex items-center gap-1 shadow-sm">
                            <i className="ph ph-crown text-yellow-500"></i> PRO
                        </span>
                    </div>
                    <div className="text-sm text-textMuted font-medium flex items-center gap-2 hidden sm:flex">
                        <i className="ph ph-shield-check text-lg"></i>
                        Unlimited Enterprise
                    </div>
                </div>
            </header>
        );

        const App = () => {
            const [mode, setMode] = useState('text'); 
            const [sourceText, setSourceText] = useState('');
            const [translatedText, setTranslatedText] = useState('');
            const [sourceLang, setSourceLang] = useState('auto');
            const [targetLang, setTargetLang] = useState('en');
            
            const [isTranslating, setIsTranslating] = useState(false);
            const [error, setError] = useState(null);
            const [copied, setCopied] = useState(false);
            const [isPlayingAudio, setIsPlayingAudio] = useState(false);
            const [isListening, setIsListening] = useState(false);
            
            // Image & Camera State
            const [imagePreview, setImagePreview] = useState(null);
            const [dragActive, setDragActive] = useState(false);
            const [ocrProgress, setOcrProgress] = useState(0);
            const [ocrStatusMsg, setOcrStatusMsg] = useState('');
            
            const videoRef = useRef(null);
            const canvasRef = useRef(null);
            const fileInputRef = useRef(null);
            const textInputRef = useRef(null);
            const lastEnterPress = useRef(0);
            const recognitionRef = useRef(null);

            useEffect(() => {
                return () => {
                    stopCamera();
                    if (recognitionRef.current) {
                        recognitionRef.current.stop();
                    }
                };
            }, []);

            const startCamera = async () => {
                try {
                    const stream = await navigator.mediaDevices.getUserMedia({ 
                        video: { facingMode: 'environment', width: { ideal: 1280 }, height: { ideal: 720 } } 
                    });
                    if (videoRef.current) {
                        videoRef.current.srcObject = stream;
                    }
                    setError(null);
                } catch (err) {
                    console.error("Camera error:", err);
                    setError("No se pudo acceder a la cámara. Verifica los permisos de tu navegador.");
                }
            };

            const stopCamera = () => {
                if (videoRef.current && videoRef.current.srcObject) {
                    const tracks = videoRef.current.srcObject.getTracks();
                    tracks.forEach(track => track.stop());
                    videoRef.current.srcObject = null;
                }
            };

            const switchMode = (newMode) => {
                if (mode === 'camera' && newMode !== 'camera') stopCamera();
                if (newMode === 'camera' && mode !== 'camera') {
                    setImagePreview(null);
                    startCamera();
                }
                setMode(newMode);
                setError(null);
            };

            const capturePhoto = () => {
                if (videoRef.current && canvasRef.current) {
                    const video = videoRef.current;
                    const canvas = canvasRef.current;
                    canvas.width = video.videoWidth;
                    canvas.height = video.videoHeight;
                    const ctx = canvas.getContext('2d');
                    ctx.drawImage(video, 0, 0, canvas.width, canvas.height);
                    setImagePreview(canvas.toDataURL('image/jpeg', 0.8));
                    stopCamera();
                }
            };

            const processFile = (file) => {
                if (file) {
                    if (file.size > 5 * 1024 * 1024) {
                        setError("La imagen es demasiado grande. Máximo 5MB.");
                        return;
                    }
                    const reader = new FileReader();
                    reader.onloadend = () => {
                        setImagePreview(reader.result);
                        setError(null);
                    };
                    reader.readAsDataURL(file);
                }
            };

            const handleFileUpload = (e) => processFile(e.target.files[0]);

            const handleDrag = (e) => {
                e.preventDefault();
                e.stopPropagation();
                if (e.type === "dragenter" || e.type === "dragover") setDragActive(true);
                else if (e.type === "dragleave") setDragActive(false);
            };

            const handleDrop = (e) => {
                e.preventDefault();
                e.stopPropagation();
                setDragActive(false);
                if (e.dataTransfer.files && e.dataTransfer.files[0]) {
                    processFile(e.dataTransfer.files[0]);
                }
            };

            const clearInput = () => {
                setSourceText('');
                setImagePreview(null);
                setTranslatedText('');
                setError(null);
                if (mode === 'camera') startCamera();
            };

            const translateChunk = async (text, fromLang, toLang) => {
                const url = `https://api.mymemory.translated.net/get?q=${encodeURIComponent(text)}&langpair=${fromLang}|${toLang}`;
                const response = await fetch(url);
                const data = await response.json();
                if (data.responseData && data.responseData.translatedText) {
                    return data.responseData.translatedText;
                }
                throw new Error("Error en el servicio de traducción.");
            };

            const handleTranslate = async () => {
                if (mode === 'text' && !sourceText.trim()) return;
                if ((mode === 'image' || mode === 'camera') && !imagePreview) return;

                setIsTranslating(true);
                setError(null);
                setTranslatedText(''); 
                setOcrProgress(0);
                setOcrStatusMsg('');

                try {
                    let textToTranslate = sourceText;

                    // 1. Extraer texto con IA Vision
                    if (mode === 'image' || mode === 'camera') {
                        const langData = LANGUAGES.find(l => l.code === sourceLang) || LANGUAGES[0];
                        setOcrStatusMsg('Iniciando motor IA...');
                        
                        const worker = await Tesseract.createWorker(langData.tess, 1, {
                            logger: m => {
                                if (m.status === 'recognizing text') {
                                    setOcrProgress(Math.round(m.progress * 100));
                                    setOcrStatusMsg('Extrayendo texto...');
                                } else if (m.status.includes('loading')) {
                                    setOcrStatusMsg('Cargando idioma...');
                                }
                            }
                        });
                        const ret = await worker.recognize(imagePreview);
                        textToTranslate = ret.data.text;
                        await worker.terminate();

                        if (!textToTranslate || !textToTranslate.trim()) {
                            throw new Error("No se pudo detectar texto legible en la imagen.");
                        }
                    }

                    // 2. Smart Chunking Algorithm (Traducción ilimitada)
                    setOcrStatusMsg('Procesando traducción...');
                    const fromLang = sourceLang === 'auto' ? 'autodetect' : sourceLang;
                    
                    // Dividimos el texto en trozos de máx 450 caracteres para no romper la API pública
                    const maxLength = 450;
                    const chunks = textToTranslate.match(new RegExp('.{1,' + maxLength + '}(\\s|$)|\\S+?(\\s|$)', 'g')) || [];
                    
                    let finalTranslation = '';
                    
                    for (let i = 0; i < chunks.length; i++) {
                        setOcrProgress(Math.round(((i) / chunks.length) * 100));
                        setOcrStatusMsg(`Traduciendo fragmentos (${i+1}/${chunks.length})...`);
                        const chunkTranslation = await translateChunk(chunks[i], fromLang, targetLang);
                        finalTranslation += chunkTranslation + ' ';
                    }

                    setTranslatedText(finalTranslation.trim());
                    
                } catch (err) {
                    console.error("Translation Error:", err);
                    setError(err.message || "Ocurrió un error al traducir. Por favor, inténtalo de nuevo.");
                } finally {
                    setIsTranslating(false);
                    setOcrStatusMsg('');
                }
            };

            const toggleDictation = () => {
                if (isListening) {
                    if (recognitionRef.current) recognitionRef.current.stop();
                    setIsListening(false);
                    return;
                }

                const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
                if (!SpeechRecognition) {
                    setError("Tu navegador no soporta el dictado por voz. Intenta usar Chrome.");
                    return;
                }

                const recognition = new SpeechRecognition();
                recognition.lang = sourceLang === 'auto' ? 'es-ES' : sourceLang; // Default a español si es auto
                recognition.continuous = true;
                recognition.interimResults = true;

                recognition.onstart = () => setIsListening(true);
                
                recognition.onresult = (event) => {
                    let interimTranscript = '';
                    let finalTranscript = '';

                    for (let i = event.resultIndex; i < event.results.length; ++i) {
                        if (event.results[i].isFinal) {
                            finalTranscript += event.results[i][0].transcript;
                        } else {
                            interimTranscript += event.results[i][0].transcript;
                        }
                    }
                    
                    if (finalTranscript) {
                        setSourceText(prev => prev + (prev ? ' ' : '') + finalTranscript);
                    }
                };

                recognition.onerror = (e) => {
                    console.error("Speech Recognition Error:", e);
                    setIsListening(false);
                };

                recognition.onend = () => setIsListening(false);

                recognitionRef.current = recognition;
                recognition.start();
            };

            const handlePlayAudio = () => {
                if (!translatedText || isPlayingAudio) return;
                if (!('speechSynthesis' in window)) {
                    setError("Tu navegador no soporta la reproducción de audio nativa.");
                    return;
                }
                setIsPlayingAudio(true);
                window.speechSynthesis.cancel();
                const utterance = new SpeechSynthesisUtterance(translatedText);
                utterance.lang = targetLang; 
                utterance.onend = () => setIsPlayingAudio(false);
                utterance.onerror = () => setIsPlayingAudio(false);
                window.speechSynthesis.speak(utterance);
            };

            const handleSwapLanguages = () => {
                if (sourceLang === 'auto') {
                    setSourceLang(targetLang);
                    setTargetLang('en');
                } else {
                    setSourceLang(targetLang);
                    setTargetLang(sourceLang);
                }
                if (mode === 'text') {
                    setSourceText(translatedText);
                    setTranslatedText(''); 
                } else {
                    setTranslatedText(''); 
                }
            };

            const handleCopy = () => {
                if (!translatedText) return;
                const textArea = document.createElement("textarea");
                textArea.value = translatedText;
                document.body.appendChild(textArea);
                textArea.select();
                try {
                    document.execCommand('copy');
                    setCopied(true);
                    setTimeout(() => setCopied(false), 2000);
                } catch (err) {
                    console.error('Failed to copy', err);
                }
                document.body.removeChild(textArea);
            };

            const handleExport = () => {
                if (!translatedText) return;
                const blob = new Blob([translatedText], { type: 'text/plain' });
                const url = URL.createObjectURL(blob);
                const a = document.createElement('a');
                a.href = url;
                a.download = `iTranslator_export_${new Date().getTime()}.txt`;
                document.body.appendChild(a);
                a.click();
                document.body.removeChild(a);
                URL.revokeObjectURL(url);
            };

            useEffect(() => {
                const handleGlobalKeyDown = (e) => {
                    // Alt + S: Swap
                    if (e.altKey && e.key.toLowerCase() === 's') {
                        e.preventDefault();
                        handleSwapLanguages();
                    }
                    // Alt + C: Copy
                    if (e.altKey && e.key.toLowerCase() === 'c' && translatedText) {
                        e.preventDefault();
                        handleCopy();
                    }
                    // Alt + P: Play
                    if (e.altKey && e.key.toLowerCase() === 'p' && translatedText) {
                        e.preventDefault();
                        handlePlayAudio();
                    }
                    // Alt + D: Download/Export
                    if (e.altKey && e.key.toLowerCase() === 'd' && translatedText) {
                        e.preventDefault();
                        handleExport();
                    }
                    // Esc: Clear
                    if (e.key === 'Escape') {
                        clearInput();
                    }
                };

                window.addEventListener('keydown', handleGlobalKeyDown);
                return () => window.removeEventListener('keydown', handleGlobalKeyDown);
            }, [translatedText, sourceLang, targetLang]);

            const handleTextareaKeyDown = (e) => {
                // Ctrl+Enter para traducir
                if ((e.ctrlKey || e.metaKey) && e.key === 'Enter') {
                    e.preventDefault();
                    handleTranslate();
                    return;
                }

                // Doble Enter para traducir
                if (e.key === 'Enter' && !e.shiftKey) {
                    const currentTime = new Date().getTime();
                    const timeDiff = currentTime - lastEnterPress.current;
                    
                    if (timeDiff < 500) { // Menos de medio segundo
                        e.preventDefault(); // Evita el salto de línea
                        // Borramos el salto de línea previo que se creó en el primer Enter
                        setSourceText(prev => prev.slice(0, -1)); 
                        handleTranslate();
                        lastEnterPress.current = 0; // Reset
                    } else {
                        lastEnterPress.current = currentTime;
                    }
                } else if (e.key !== 'Enter') {
                    lastEnterPress.current = 0; // Reset if typing other things
                }
            };

            return (
                <div className="min-h-screen flex flex-col bg-bgMain text-textMain">
                    <Header />

                    <main className="flex-grow w-full max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8 flex flex-col">
                        
                        {/* Selector de Idiomas */}
                        <div className="bg-bgSoft rounded-t-xl sm:rounded-2xl border border-borderSoft p-2 mb-0 sm:mb-6 flex flex-col sm:flex-row items-center justify-between gap-2 relative z-10 shadow-lg">
                            
                            {/* Idioma Origen */}
                            <div className="w-full sm:w-[45%] flex items-center">
                                <i className="ph ph-translate absolute left-4 text-textMuted pointer-events-none hidden sm:block"></i>
                                <select 
                                    className="w-full appearance-none bg-bgMain border border-borderSoft hover:border-gray-500 text-textMain text-sm rounded-lg focus:ring-1 focus:ring-white focus:border-white block p-3 sm:pl-10 outline-none transition-colors cursor-pointer font-medium"
                                    value={sourceLang}
                                    onChange={(e) => setSourceLang(e.target.value)}
                                >
                                    {LANGUAGES.map(lang => (
                                        <option key={lang.code} value={lang.code}>{lang.name}</option>
                                    ))}
                                </select>
                                <div className="pointer-events-none absolute inset-y-0 right-0 flex items-center px-4 text-textMuted sm:hidden md:flex md:right-auto md:left-[42%] lg:left-[43%]">
                                    <i className="ph ph-caret-down"></i>
                                </div>
                            </div>

                            {/* Botón Intercambiar */}
                            <button 
                                onClick={handleSwapLanguages}
                                className="bg-bgMain hover:bg-[#1a1a1a] border border-borderSoft text-textMuted hover:text-white p-2.5 rounded-full transition-all duration-200 group active:scale-95 z-20 shadow-md"
                                title="Intercambiar idiomas (Alt+S)"
                            >
                                <i className="ph ph-arrows-left-right text-xl group-hover:rotate-180 transition-transform duration-300"></i>
                            </button>

                            {/* Idioma Destino */}
                            <div className="w-full sm:w-[45%] flex items-center relative">
                                <select 
                                    className="w-full appearance-none bg-bgMain border border-borderSoft hover:border-gray-500 text-textMain text-sm rounded-lg focus:ring-1 focus:ring-white focus:border-white block p-3 outline-none transition-colors cursor-pointer font-medium"
                                    value={targetLang}
                                    onChange={(e) => setTargetLang(e.target.value)}
                                >
                                    {LANGUAGES.map(lang => (
                                        <option key={lang.code} value={lang.code}>{lang.name}</option>
                                    ))}
                                </select>
                                <div className="pointer-events-none absolute inset-y-0 right-0 flex items-center px-4 text-textMuted">
                                    <i className="ph ph-caret-down"></i>
                                </div>
                            </div>
                        </div>

                        {/* Áreas de Contenido */}
                        <div className="flex-grow flex flex-col lg:flex-row bg-bgSoft rounded-b-xl sm:rounded-2xl border border-borderSoft sm:border-t-0 lg:border-t overflow-hidden min-h-[500px] shadow-2xl">
                            
                            {/* Panel Izquierdo: Origen */}
                            <div className="flex-1 flex flex-col border-b lg:border-b-0 lg:border-r border-borderSoft relative group bg-bgSoft">
                                
                                {/* Tabs de Entrada */}
                                <div className="flex border-b border-borderSoft bg-[#000000]">
                                    <button 
                                        onClick={() => switchMode('text')}
                                        className={`flex-1 py-3 px-4 text-sm font-medium flex items-center justify-center gap-2 transition-colors ${mode === 'text' ? 'text-white border-b-2 border-white bg-bgSoft' : 'text-textMuted hover:text-white hover:bg-[#111111]'}`}
                                    >
                                        <i className="ph ph-text-t text-lg"></i> Texto
                                    </button>
                                    <button 
                                        onClick={() => switchMode('image')}
                                        className={`flex-1 py-3 px-4 text-sm font-medium flex items-center justify-center gap-2 transition-colors ${mode === 'image' ? 'text-white border-b-2 border-white bg-bgSoft' : 'text-textMuted hover:text-white hover:bg-[#111111]'}`}
                                    >
                                        <i className="ph ph-image text-lg"></i> Imagen
                                    </button>
                                    <button 
                                        onClick={() => switchMode('camera')}
                                        className={`flex-1 py-3 px-4 text-sm font-medium flex items-center justify-center gap-2 transition-colors ${mode === 'camera' ? 'text-white border-b-2 border-white bg-bgSoft' : 'text-textMuted hover:text-white hover:bg-[#111111]'}`}
                                    >
                                        <i className="ph ph-camera text-lg"></i> Cámara
                                    </button>
                                </div>

                                {}
                                <div className="flex-grow flex flex-col relative overflow-hidden min-h-[250px]">
                                    {mode === 'text' && (
                                        <div className="flex-grow flex flex-col relative">
                                            <textarea
                                                ref={textInputRef}
                                                className="flex-grow w-full resize-none p-6 text-lg text-textMain placeholder-textMuted outline-none bg-transparent"
                                                placeholder="Ingresa texto, pega un documento o usa el micrófono..."
                                                value={sourceText}
                                                onChange={(e) => setSourceText(e.target.value)}
                                                onKeyDown={handleTextareaKeyDown}
                                                spellCheck="false"
                                            />
                                            
                                            {/* Micrófono Dictado */}
                                            <button 
                                                onClick={toggleDictation}
                                                className="absolute bottom-6 left-6 text-textMuted hover:text-white transition-colors group flex items-center gap-2"
                                                title="Dictar por voz"
                                            >
                                                <div className={`relative flex items-center justify-center w-10 h-10 rounded-full border ${isListening ? 'border-red-500 bg-red-500/10 text-red-500' : 'border-borderSoft bg-bgMain hover:border-gray-500'}`}>
                                                    {isListening && <span className="absolute inset-0 rounded-full bg-red-500/30 animate-ping-slow"></span>}
                                                    <i className={`ph ${isListening ? 'ph-stop-circle' : 'ph-microphone'} text-xl`}></i>
                                                </div>
                                            </button>

                                            {/* Indicador Unlimited & Double Enter */}
                                            <div className="absolute bottom-4 right-4 flex items-center gap-3 justify-end pointer-events-none">
                                                <span className="text-[10px] text-textMuted hidden sm:block bg-bgMain px-2 py-1 rounded border border-borderSoft">
                                                    Ctrl+↵ / Doble ↵ para traducir
                                                </span>
                                                <span className="text-xs font-bold px-2 py-1 rounded-md bg-gradient-to-r from-gray-800 to-black border border-gray-600 text-white shadow-sm flex items-center gap-1">
                                                    <i className="ph ph-infinity text-sm"></i>
                                                    {sourceText.length} 
                                                </span>
                                            </div>
                                        </div>
                                    )}

                                    {mode === 'image' && (
                                        <div 
                                            className="flex-grow p-6 flex flex-col items-center justify-center bg-bgSoft relative"
                                            onDragEnter={handleDrag}
                                            onDragLeave={handleDrag}
                                            onDragOver={handleDrag}
                                            onDrop={handleDrop}
                                        >
                                            {imagePreview ? (
                                                <div className="relative w-full h-full flex items-center justify-center">
                                                    <img src={imagePreview} alt="Preview" className="max-h-[350px] object-contain rounded-lg shadow-sm border border-borderSoft" />
                                                </div>
                                            ) : (
                                                <div 
                                                    className={`w-full h-full border-2 border-dashed rounded-xl flex flex-col items-center justify-center text-textMuted transition-all cursor-pointer group p-6 text-center
                                                        ${dragActive ? 'border-white bg-[#1a1a1a] text-white scale-[0.98]' : 'border-borderSoft hover:bg-[#1a1a1a] hover:border-gray-400 hover:text-white'}`}
                                                    onClick={() => fileInputRef.current?.click()}
                                                >
                                                    <div className={`p-4 rounded-full border mb-3 transition-transform ${dragActive ? 'bg-white text-black border-white scale-110' : 'bg-bgMain border-borderSoft group-hover:scale-110'}`}>
                                                        <i className="ph ph-upload-simple text-3xl text-current"></i>
                                                    </div>
                                                    <p className="font-medium text-current">{dragActive ? 'Suelta la imagen aquí' : 'Sube o arrastra una imagen con texto'}</p>
                                                    <p className="text-sm mt-1 opacity-75">Soporta JPG, PNG (Max 5MB)</p>
                                                    <input type="file" ref={fileInputRef} onChange={handleFileUpload} accept="image/*" className="hidden" />
                                                </div>
                                            )}
                                        </div>
                                    )}

                                    {mode === 'camera' && (
                                        <div className="flex-grow bg-black relative flex items-center justify-center overflow-hidden rounded-b-none">
                                            {imagePreview ? (
                                                 <img src={imagePreview} alt="Captured" className="w-full h-full object-contain" />
                                            ) : (
                                                <>
                                                    <video ref={videoRef} autoPlay playsInline className="w-full h-full object-cover" />
                                                    <button 
                                                        onClick={capturePhoto}
                                                        className="absolute bottom-6 left-1/2 -translate-x-1/2 w-16 h-16 bg-transparent rounded-full border-4 border-white active:scale-95 transition-transform flex items-center justify-center z-10 hover:bg-white/20 group shadow-lg"
                                                    >
                                                        <div className="w-10 h-10 rounded-full bg-white transition-colors shadow-sm"></div>
                                                    </button>
                                                    <canvas ref={canvasRef} className="hidden" />
                                                </>
                                            )}
                                        </div>
                                    )}

                                    {/* Botón Clear Unificado */}
                                    {((mode === 'text' && sourceText) || ((mode === 'image' || mode === 'camera') && imagePreview)) && (
                                        <button 
                                            onClick={clearInput}
                                            className="absolute top-4 right-4 text-textMuted bg-bgMain hover:text-white p-1.5 rounded-md hover:bg-red-500 hover:text-white hover:border-red-500 transition-colors border border-borderSoft z-20 shadow-sm"
                                            title="Borrar todo (Esc)"
                                        >
                                            <i className="ph ph-trash text-lg"></i>
                                        </button>
                                    )}
                                </div>

                                {/* Barra inferior panel origen */}
                                <div className="p-4 flex items-center justify-between border-t border-borderSoft bg-bgMain">
                                    <div className="text-xs text-textMuted font-medium flex items-center gap-2">
                                        {mode === 'text' ? (
                                            <><i className="ph ph-text-t"></i> Entrada Ilimitada PRO</>
                                        ) : (
                                            <><i className="ph ph-sparkle text-white"></i> Visión IA</>
                                        )}
                                        {isTranslating && ocrStatusMsg && (
                                            <span className="animate-pulse text-white bg-[#1a1a1a] px-2 py-0.5 rounded border border-borderSoft hidden sm:inline-block">
                                                {ocrStatusMsg} {ocrProgress > 0 && ocrProgress < 100 ? `${ocrProgress}%` : ''}
                                            </span>
                                        )}
                                    </div>
                                    <button
                                        onClick={handleTranslate}
                                        disabled={(mode === 'text' && !sourceText.trim()) || ((mode === 'image' || mode === 'camera') && !imagePreview) || isTranslating}
                                        className={`flex items-center gap-2 px-6 py-2.5 rounded-lg font-semibold text-sm transition-all duration-200 border 
                                            ${((mode === 'text' && !sourceText.trim()) || ((mode === 'image' || mode === 'camera') && !imagePreview))
                                                ? 'bg-[#1a1a1a] text-[#4d4d4d] border-transparent cursor-not-allowed' 
                                                : isTranslating 
                                                    ? 'bg-white text-black border-white cursor-wait'
                                                    : 'bg-white text-black border-white hover:bg-gray-200 active:scale-[0.98] shadow-[0_0_15px_rgba(255,255,255,0.1)] hover:shadow-[0_0_20px_rgba(255,255,255,0.2)]'
                                            }`}
                                    >
                                        {isTranslating ? (
                                            <>
                                                <i className="ph ph-spinner-gap animate-spin text-lg"></i>
                                                {ocrProgress > 0 && ocrProgress < 100 ? `${ocrProgress}%` : 'Procesando...'}
                                            </>
                                        ) : (
                                            <>
                                                <i className="ph ph-magic-wand text-lg"></i>
                                                Traducir
                                            </>
                                        )}
                                    </button>
                                </div>
                            </div>

                            {}
                            <div className={`flex-1 flex flex-col relative ${isTranslating ? 'bg-bgSoft animate-pulse-subtle' : 'bg-bgSoft'}`}>
                                
                                {error ? (
                                    <div className="flex-grow flex items-center justify-center p-6 text-white flex-col gap-3 text-center border border-borderSoft m-4 rounded-xl bg-[#1a1a1a]">
                                        <i className="ph ph-warning-circle text-4xl text-red-400"></i>
                                        <p className="font-medium text-red-200">{error}</p>
                                    </div>
                                ) : (
                                    <div className="flex-grow p-6 relative">
                                        {translatedText ? (
                                            <p className="text-lg text-textMain whitespace-pre-wrap leading-relaxed">
                                                {translatedText}
                                            </p>
                                        ) : (
                                            <div className="absolute inset-0 flex items-center justify-center text-textMuted flex-col gap-4 p-6 text-center">
                                                <div className="w-20 h-20 rounded-full border border-borderSoft bg-bgMain flex items-center justify-center opacity-50">
                                                    <i className="ph ph-translate text-4xl"></i>
                                                </div>
                                                <p className="text-sm font-medium opacity-60">
                                                    {mode === 'text' 
                                                        ? 'La traducción aparecerá aquí' 
                                                        : 'El texto extraído y traducido aparecerá aquí'}
                                                </p>
                                            </div>
                                        )}
                                    </div>
                                )}

                                {/* Barra inferior panel destino */}
                                <div className="p-4 flex items-center justify-between border-t border-borderSoft bg-bgMain">
                                    <button
                                        onClick={handlePlayAudio}
                                        disabled={!translatedText || isPlayingAudio}
                                        className={`flex items-center gap-2 px-4 py-2 rounded-lg font-medium text-sm transition-all duration-200
                                            ${!translatedText 
                                                ? 'text-[#4d4d4d] cursor-not-allowed opacity-50 hidden' 
                                                : isPlayingAudio
                                                    ? 'bg-white text-black border border-white'
                                                    : 'bg-transparent border border-borderSoft text-textMain hover:bg-[#1a1a1a] active:scale-[0.98]'
                                            }`}
                                        title="Escuchar traducción (Alt+P)"
                                    >
                                        <i className={`ph ${isPlayingAudio ? 'ph-speaker-high' : 'ph-speaker-low'} text-lg`}></i>
                                        <span className="hidden sm:inline">{isPlayingAudio ? 'Reproduciendo...' : 'Escuchar'}</span>
                                    </button>

                                    <div className="flex items-center gap-2">
                                        <button
                                            onClick={handleExport}
                                            disabled={!translatedText}
                                            className={`flex items-center gap-2 px-4 py-2 rounded-lg font-medium text-sm transition-all duration-200
                                                ${!translatedText 
                                                    ? 'text-[#4d4d4d] cursor-not-allowed opacity-50 hidden md:flex' 
                                                    : 'bg-transparent border border-borderSoft text-textMain hover:bg-[#1a1a1a] active:scale-[0.98] hidden md:flex'
                                                }`}
                                            title="Exportar a .txt (Alt+D)"
                                        >
                                            <i className="ph ph-download-simple text-lg"></i>
                                            Exportar
                                        </button>
                                        <button
                                            onClick={handleCopy}
                                            disabled={!translatedText}
                                            className={`flex items-center gap-2 px-4 py-2 rounded-lg font-medium text-sm transition-all duration-200
                                                ${!translatedText 
                                                    ? 'text-[#4d4d4d] cursor-not-allowed opacity-50' 
                                                    : copied 
                                                        ? 'bg-white text-black border border-white' 
                                                        : 'bg-transparent border border-borderSoft text-textMain hover:bg-[#1a1a1a] active:scale-[0.98]'
                                                }`}
                                            title="Copiar texto (Alt+C)"
                                        >
                                            {copied ? (
                                                <><i className="ph ph-check text-lg"></i> Copiado</>
                                            ) : (
                                                <><i className="ph ph-copy text-lg"></i> Copiar</>
                                            )}
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        {}
                        {/* Atajos de Teclado */}
                        <div className="mt-8 flex flex-wrap items-center justify-center gap-4 text-xs text-textMuted font-medium opacity-70 hover:opacity-100 transition-opacity">
                            <div className="flex items-center gap-1"><kbd className="bg-[#1a1a1a] border border-borderSoft rounded px-1.5 py-0.5 font-mono text-[10px] text-gray-300">Ctrl+↵</kbd> Traducir</div>
                            <div className="flex items-center gap-1"><kbd className="bg-[#1a1a1a] border border-borderSoft rounded px-1.5 py-0.5 font-mono text-[10px] text-gray-300">Alt+S</kbd> Intercambiar</div>
                            <div className="flex items-center gap-1"><kbd className="bg-[#1a1a1a] border border-borderSoft rounded px-1.5 py-0.5 font-mono text-[10px] text-gray-300">Alt+C</kbd> Copiar</div>
                            <div className="flex items-center gap-1"><kbd className="bg-[#1a1a1a] border border-borderSoft rounded px-1.5 py-0.5 font-mono text-[10px] text-gray-300">Alt+D</kbd> Exportar</div>
                            <div className="flex items-center gap-1"><kbd className="bg-[#1a1a1a] border border-borderSoft rounded px-1.5 py-0.5 font-mono text-[10px] text-gray-300">Esc</kbd> Limpiar</div>
                        </div>
                        
                        {/* Sello Corporativo i.Logic */}
                        <div className="mt-10 flex flex-col items-center justify-center border-t border-borderSoft pt-8 pb-4 relative">
                            <div className="absolute -top-3 bg-bgMain px-4 flex items-center gap-2 text-textMuted">
                                <span className="text-[10px] uppercase tracking-[0.2em] font-semibold opacity-40">Desarrollado por</span>
                            </div>
                            
                            <div className="flex items-center gap-3 group cursor-default mt-2">
                                <div className="w-9 h-9 rounded-xl bg-gradient-to-br from-[#1a1a1a] to-[#000000] border border-[#333333] flex items-center justify-center shadow-lg group-hover:border-gray-500 transition-all duration-300 relative overflow-hidden group-hover:shadow-[0_0_15px_rgba(255,255,255,0.1)]">
                                    <div className="absolute inset-0 bg-gradient-to-r from-transparent via-white/10 to-transparent -translate-x-full group-hover:animate-[shimmer_1.5s_infinite]"></div>
                                    <i className="ph ph-hexagon text-white text-xl"></i>
                                </div>
                                <div className="flex flex-col">
                                    <span className="text-xl font-black tracking-tight text-white transition-colors leading-none">
                                        i.<span className="text-transparent bg-clip-text bg-gradient-to-r from-gray-200 to-gray-500">Logic</span>
                                    </span>
                                    <span className="text-[9px] text-textMuted font-medium tracking-[0.1em] uppercase mt-1">
                                        Enterprise Solutions
                                    </span>
                                </div>
                            </div>

                            <div className="mt-6 text-center text-[10px] text-[#4d4d4d] flex items-center justify-center gap-2">
                                 i.Translator Pro • Powered by Smart Chunking & Vision AI
                            </div>
                        </div>

                    </main>
                </div>
            );
        };

        const root = ReactDOM.createRoot(document.getElementById('root'));
        root.render(<App />);
    </script>
</body>
</html>
